rules_version = '2';
// Retail-Handover-Log — Firestore rules (ADR-001)
// บังคับผ่าน Firebase Anonymous Auth · ล็อกรายการที่ส่งมอบแล้วจริงที่ server
service cloud.firestore {
  match /databases/{database}/documents {

    match /parcelLog/{id} {
      // อ่าน: ต้องผ่าน auth (แอป sign-in anonymous ให้อัตโนมัติ)
      allow read: if request.auth != null;

      // สร้าง: ต้องมีผู้บันทึก + รูปพัสดุอย่างน้อย 1 (บังคับระดับ server)
      allow create: if request.auth != null
        && request.resource.data.recordedBy is string
        && request.resource.data.recordedBy.size() > 0
        && request.resource.data.itemPhotos is list
        && request.resource.data.itemPhotos.size() >= 1;

      // ลบ: ทำได้เฉพาะรายการที่ยัง "ค้างอยู่" (pending)
      allow delete: if request.auth != null
        && resource.data.status == 'pending';

      // แก้: เฉพาะ pending + ต้องคง invariant (recordedBy + รูปพัสดุ≥1) กันการ strip ฟิลด์บังคับ
      // หมายเหตุ: merge:true → request.resource.data = เอกสารหลัง merge เต็มใบ (deliver flow จึงผ่าน)
      allow update: if request.auth != null
        && resource.data.status == 'pending'
        && request.resource.data.recordedBy is string
        && request.resource.data.recordedBy.size() > 0
        && request.resource.data.itemPhotos is list
        && request.resource.data.itemPhotos.size() >= 1;
    }
  }
}
